# ============================================================================
# 어뷰티(A-Beauty) — 환경변수 설정
# 이 파일을 복사해 .env.local 로 저장한 뒤 실제 값을 채워주세요.
# ⚠️  .env.local 은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)
# ============================================================================

# ── 사이트 URL (OG 메타태그 절대경로 기준) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Google Analytics 4 ─────────────────────────────────────────────────────
# GA4 → 관리 → 데이터 스트림 → 측정 ID (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Microsoft Clarity ──────────────────────────────────────────────────────
# clarity.microsoft.com → 프로젝트 설정 → 추적 코드 → 프로젝트 ID
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ── Google Sheets API (고객 데이터 연동용) ──────────────────────────────────
# 1. 스프레드시트 URL의 긴 ID 부분
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# 2. 구글 클라우드 서비스 계정 이메일
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# 3. 서비스 계정 JSON의 private_key 값 (-----BEGIN PRIVATE KEY----- 부터 끝까지)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
