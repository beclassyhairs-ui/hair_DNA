# ============================================================================
# 어뷰티(A-Beauty) — 환경변수 설정
# 이 파일을 복사해 .env.local 로 저장한 뒤 실제 값을 채워주세요.
# ⚠️  .env.local 은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)
# ============================================================================

# ── 사이트 URL (OG 메타태그 절대경로 기준) ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── Google Analytics 4 ─────────────────────────────────────────────────────
# GA4 → 관리 → 데이터 스트림 → 측정 ID (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Microsoft Clarity ──────────────────────────────────────────────────────
# clarity.microsoft.com → 프로젝트 설정 → 추적 코드 → 프로젝트 ID
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ── Google Sheets API (고객 데이터 연동용) ──────────────────────────────────
# 1. 스프레드시트 URL의 긴 ID 부분
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# 2. 구글 클라우드 서비스 계정 이메일
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# 3. 서비스 계정 JSON의 private_key 값 (-----BEGIN PRIVATE KEY----- 부터 끝까지)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Supabase (이벤트 트래킹 DB) ─────────────────────────────────────────────
# Supabase 대시보드 → Project Settings → API
# 1. 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# 2. anon(public) key — 브라우저에 노출되는 키. INSERT만 허용되고 SELECT는 막혀있어야 안전함(RLS 정책 참고)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 3. service_role key — ⚠️ 절대 NEXT_PUBLIC_ 접두어 붙이지 말 것(서버 전용, RLS 우회 가능한 최고권한 키)
#    어드민 대시보드 API 라우트(app/api/admin/events)에서만 사용됨
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── 관리자 게이트 비밀번호 (서버 전용) ──────────────────────────────────────
# ⚠️ 절대 NEXT_PUBLIC_ 접두어 붙이지 말 것. 이 값이 /admin/* 과 /api/admin/* 전체를
#    보호하는 단일 공유 비밀번호다. middleware.ts가 이 값으로 세션 쿠키를 검증한다.
#    미설정 시 관리자 영역은 fail-closed(500)로 잠긴다.
#    로컬(.env.local)과 Vercel 환경변수(Production/Preview) 양쪽에 동일하게 설정할 것.
#    충분히 긴 랜덤 문자열 권장(예: openssl rand -base64 24).
ADMIN_SECRET=your_admin_password_here

# ── Sentry (에러 모니터링) ──────────────────────────────────────────────────
# sentry.io → 프로젝트 생성(Next.js) → Settings → Client Keys(DSN)
# 이 값이 없으면 Sentry는 완전 비활성(no-op) — 코드는 그대로 두고 값만 넣으면 동작한다.
# 1. DSN — 브라우저·서버 공통. NEXT_PUBLIC_ 접두어라 클라이언트 번들에도 포함됨(DSN은 공개돼도 안전).
NEXT_PUBLIC_SENTRY_DSN=

# 2. 소스맵 업로드용(선택) — 없으면 업로드만 건너뛰고 에러 수집은 정상 동작.
#    Sentry → Settings → Auth Tokens 에서 발급. org/project는 프로젝트 슬러그.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# 📌 알림은 코드가 아니라 Sentry 대시보드에서 설정한다:
#    Settings → Alerts → 이슈 알림 → 이메일 채널(beclassyhairs@gmail.com 등) 지정.
